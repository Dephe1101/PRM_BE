{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "#configs/*": [
        "./src/configs/*"
      ],
      "#constants/*": [
        "./src/constants/*"
      ],
      "#middlewares/*": [
        "./src/middlewares/*"
      ],
      "#models/*": [
        "./src/models/*"
      ],
      "#repositories/*": [
        "./src/repositories/*"
      ],
      "#services/*": [
        "./src/services/*"
      ],
      "#controllers/*": [
        "./src/controllers/*"
      ],
      "#routes/*": [
        "./src/routes/*"
      ],
      "#utils/*": [
        "./src/utils/*"
      ],
      "#validations/*": [
        "./src/validations/*"
      ],
      "#types/*": [
        "./src/types/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "ts-node": {
    "files": true
  }
}